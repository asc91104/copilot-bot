PORT=3000
# Optional: if not set, SDK will use logged-in GitHub user if available.
GITHUB_TOKEN=

# Telegram bot settings
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_PATH=/webhooks/telegram
TELEGRAM_WEBHOOK_SECRET=
# Optional: e.g. https://your-domain.com
TELEGRAM_WEBHOOK_URL=

# Telegram network tuning
TELEGRAM_PREFER_IPV4=true
TELEGRAM_API_TIMEOUT_MS=15000
TELEGRAM_API_RETRIES=1
# Optional API base URL override
TELEGRAM_API_BASE_URL=https://api.telegram.org

